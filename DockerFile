FROM ubuntu:latest

# Install necessary system libraries for the server executable
RUN apt-get update && apt-get install -y libc6 libssl-dev ca-certificates && rm -rf /var/lib/apt/lists/*

# Set the working directory inside Render
WORKDIR /app

# Copy the server executable and config file from your repository
COPY central-server /app/central-server
COPY config.toml /app/config.toml

# Make sure Render has permission to run the executable
RUN chmod +x /app/central-server

# Tell the server to listen on the port Render assigns dynamically
ENV GLOBED_PORT=10000
EXPOSE 10000

# Start the server
CMD ["./central-server"]
